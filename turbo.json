{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "db:generate": {
      "inputs": ["prisma/schema.prisma", "prisma.config.ts"],
      "outputs": ["src/generated/prisma/**"]
    },
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/schema.prisma"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["db:generate"]
    },
    "check-types": {
      "dependsOn": ["db:generate"]
    },
    "test": {
      "dependsOn": ["db:generate"]
    },
    "format:check": {},
    "format": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["db:generate"],
      "cache": false,
      "persistent": true
    }
  }
}
