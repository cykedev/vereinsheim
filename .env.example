# vereinsheim — Production Environment
# Kopieren nach .env und alle Werte setzen.
# Passwörter: openssl rand -base64 32
# NEXTAUTH_SECRETs: openssl rand -base64 48

# === Domain & TLS ===
DOMAIN=example.com
RINGWERK_HOST=ringwerk.example.com
TREFFSICHER_HOST=training.example.com
ACME_EMAIL=admin@example.com

# === Docker Images ===
# Docker-Hub-Account, unter dem die Images gepusht werden.
DOCKER_USER=cyke
# Image-Tags. Default ist latest, kann auf eine SHA gepinnt werden.
RINGWERK_TAG=latest
RINGWERK_MIGRATOR_TAG=latest-migrator
TREFFSICHER_TAG=latest
TREFFSICHER_MIGRATOR_TAG=latest-migrator

# === Postgres ===
# Superuser, nur intern verwendet (Admin-Tasks, Backups, Restore).
POSTGRES_PASSWORD=
# Per-App-User mit Owner-Rechten ausschließlich auf der eigenen DB.
RINGWERK_DB_PASSWORD=
TREFFSICHER_DB_PASSWORD=

# === Ringwerk ===
RINGWERK_NEXTAUTH_SECRET=
RINGWERK_SEED_ADMIN_EMAIL=admin@example.com
RINGWERK_SEED_ADMIN_PASSWORD=

# === Treffsicher ===
TREFFSICHER_NEXTAUTH_SECRET=
TREFFSICHER_ADMIN_EMAIL=admin@example.com
TREFFSICHER_ADMIN_PASSWORD=

# === Beide Apps gemeinsam ===
DISPLAY_TIME_ZONE=Europe/Berlin
