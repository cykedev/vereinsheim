{
  "name": "vereinsheim",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "db:generate": "turbo run db:generate",
    "check": "turbo run lint format:check test check-types build"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}
