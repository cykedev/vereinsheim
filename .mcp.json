{
  "mcpServers": {
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ],
      "env": {
        "CODEGRAPH_TELEMETRY": "0"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "node",
      "args": [
        ".claude/hooks/memory-server.mjs"
      ]
    }
  }
}
