#!/usr/bin/env bash
# vereinsheim — Operations CLI
#
# One tool to drive setup, deploy, backup, restore, and recovery.
# All subcommands are also reachable via the interactive menu (./scripts/vereinsheim).
#
# Subcommands wrap the per-task scripts (deploy.sh, backup.sh, restore.sh)
# instead of duplicating their logic.
set -euo pipefail

# ---------- Path setup ----------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
cd "$REPO_DIR"

ENV_FILE="$REPO_DIR/.env"
ENV_EXAMPLE="$REPO_DIR/.env.example"
LOCAL_CONFIG="$REPO_DIR/.vereinsheim.local"
LOCAL_ENV_FILE="$REPO_DIR/.env.local"
LOCAL_COMPOSE_FILE="$REPO_DIR/compose.local.yml"
DEV_COMPOSE_FILE="$REPO_DIR/docker-compose.dev.yml"
LOCAL_BACKUP_DIR="$REPO_DIR/backups"
BACKUP_DIR_DEFAULT="/var/backups/vereinsheim"

# ---------- Colors ----------
if [[ -t 1 ]]; then
	BOLD=$'\033[1m'
	RESET=$'\033[0m'
	RED=$'\033[31m'
	GREEN=$'\033[32m'
	YELLOW=$'\033[33m'
	BLUE=$'\033[34m'
	DIM=$'\033[2m'
else
	BOLD="" RESET="" RED="" GREEN="" YELLOW="" BLUE="" DIM=""
fi

info() { echo "${BLUE}==>${RESET} $*"; }
ok() { echo "${GREEN}✓${RESET} $*"; }
warn() { echo "${YELLOW}!!${RESET} $*" >&2; }
err() { echo "${RED}✗${RESET} $*" >&2; }
hr() { echo "${DIM}──────────────────────────────────────────────────${RESET}"; }

# ---------- Prompt helpers ----------
confirm() {
	local prompt="${1:-Continue?}" default="${2:-N}"
	local hint="[y/N]"
	[[ "$default" == "Y" ]] && hint="[Y/n]"
	local reply
	read -r -p "$prompt $hint " reply
	reply="${reply:-$default}"
	[[ "$reply" =~ ^[Yy]$ ]]
}

ask() {
	local question="$1" default="${2:-}"
	local reply
	if [[ -n "$default" ]]; then
		read -r -p "  $question [${DIM}${default}${RESET}]: " reply
		echo "${reply:-$default}"
	else
		read -r -p "  $question: " reply
		echo "$reply"
	fi
}

ask_secret() {
	# Asks for a secret. Empty input = generate <len>-byte random base64.
	local question="$1" len="${2:-32}"
	local reply
	read -r -s -p "  $question (Enter = generate): " reply
	echo >&2
	if [[ -z "$reply" ]]; then
		openssl rand -base64 "$len" | tr -d '\n=+/' | cut -c1-"$len"
	else
		echo "$reply"
	fi
}

ask_validated() {
	local question="$1" validator="$2" default="${3:-}"
	local value
	while :; do
		value="$(ask "$question" "$default")"
		if "$validator" "$value"; then
			echo "$value"
			return
		fi
		warn "Eingabe ungültig — bitte erneut."
	done
}

# ---------- Validators ----------
is_email() { [[ "$1" =~ ^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]]; }
is_hostname() { [[ "$1" =~ ^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$ ]]; }
is_min_chars() { local n="$2"; [[ ${#1} -ge $n ]]; }
make_min_validator() { local n="$1"; eval "_min_${n}() { is_min_chars \"\$1\" $n; }"; echo "_min_${n}"; }

# ---------- env handling ----------
require_env() {
	if [[ ! -f "$ENV_FILE" ]]; then
		err ".env fehlt im Repo-Root."
		echo "  → Lege sie an mit:  ./scripts/vereinsheim setup"
		exit 1
	fi
}

read_env_var() {
	# Print value of <KEY> from .env (ignores comments, allows = in value)
	local key="$1"
	[[ -f "$ENV_FILE" ]] || return 1
	awk -F= -v k="$key" '
		/^[[:space:]]*#/ { next }
		$1 == k { sub(/^[^=]*=/, ""); print; exit }
	' "$ENV_FILE"
}

write_env_var() {
	# In-place set <KEY>=<VALUE> in .env. Appends if missing.
	local key="$1" value="$2"
	local escaped
	escaped="$(printf '%s\n' "$value" | sed -e 's/[\/&]/\\&/g')"
	if grep -q "^${key}=" "$ENV_FILE"; then
		sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$ENV_FILE" && rm -f "$ENV_FILE.bak"
	else
		echo "${key}=${value}" >>"$ENV_FILE"
	fi
}

env_keys_from_example() {
	# All variable names declared in .env.example
	awk -F= '/^[A-Z][A-Z0-9_]*=/ { print $1 }' "$ENV_EXAMPLE"
}

is_valid_app() {
	[[ "${1:-}" =~ ^(ringwerk|treffsicher)$ ]]
}

# ---------- local config ----------
# .vereinsheim.local enthält lokale Konfiguration: VPS_HOST, VPS_REPO_PATH,
# DOCKER_USER. Wird gebraucht für build, release, ssh, remote.
load_local_config() {
	[[ -f "$LOCAL_CONFIG" ]] || return 1
	# shellcheck disable=SC1090
	set -a
	source "$LOCAL_CONFIG"
	set +a
}

require_local_config() {
	if ! load_local_config; then
		err ".vereinsheim.local fehlt — bitte einmalig anlegen mit:"
		echo "    ./scripts/vereinsheim local-setup"
		exit 1
	fi
	: "${VPS_HOST:?VPS_HOST in .vereinsheim.local fehlt}"
	: "${VPS_REPO_PATH:?VPS_REPO_PATH in .vereinsheim.local fehlt}"
	: "${DOCKER_USER:?DOCKER_USER in .vereinsheim.local fehlt}"
}

is_local_mode() { [[ -f "$LOCAL_CONFIG" ]]; }

# ---------- docker helpers ----------
require_docker() {
	if ! command -v docker >/dev/null 2>&1; then
		err "docker nicht gefunden. Installiere Docker zuerst."
		exit 1
	fi
	if ! docker info >/dev/null 2>&1; then
		err "Docker daemon nicht erreichbar."
		exit 1
	fi
}

db_running() {
	docker compose ps --status running --services 2>/dev/null | grep -qx db
}

# Der geteilte Dev-Postgres (docker-compose.dev.yml, Projekt vereinsheim-dev)
# und der lokale Test-Stack (compose.yml + compose.local.yml) binden beide
# Host-Port 5432. Läuft die Dev-DB, scheitert local-up mit "port is already
# allocated" — daher vorher stoppen (stop, nicht down: Volume + Container
# bleiben, schnell wieder hochfahrbar).
stop_dev_db_if_running() {
	[[ -f "$DEV_COMPOSE_FILE" ]] || return 0
	if docker compose -f "$DEV_COMPOSE_FILE" ps --status running --services 2>/dev/null | grep -qx db; then
		info "Dev-Postgres (vereinsheim-dev) belegt Port 5432 — stoppe ihn für den Test-Stack …"
		docker compose -f "$DEV_COMPOSE_FILE" stop db >/dev/null 2>&1 || true
		ok "Dev-Postgres gestoppt  ${DIM}(wieder hoch: docker compose -f docker-compose.dev.yml up -d)${RESET}"
	fi
}

# Wrapper: docker compose mit lokalem Override und .env.local
local_compose() {
	docker compose \
		-f "$REPO_DIR/compose.yml" \
		-f "$LOCAL_COMPOSE_FILE" \
		--env-file "$LOCAL_ENV_FILE" \
		"$@"
}

# Wrapper: docker compose gegen den Dev-Stack (docker-compose.dev.yml,
# Projekt vereinsheim-dev). Bewusst getrennt vom Prod-Stack und vom
# local_compose-Simulator — eigener Container/Volume, DB-User postgres/postgres,
# Apps laufen auf dem Host via `pnpm dev`.
dev_compose() {
	docker compose -f "$DEV_COMPOSE_FILE" "$@"
}

require_local_env() {
	if [[ ! -f "$LOCAL_ENV_FILE" ]]; then
		err ".env.local fehlt — bitte zuerst ausführen:"
		echo "    ./scripts/vereinsheim local-pull"
		exit 1
	fi
}

# ============================================================
# Commands
# ============================================================

cmd_help() {
	cat <<-EOF
		${BOLD}vereinsheim${RESET} — Operations CLI

		${BOLD}USAGE${RESET}
		  ./scripts/vereinsheim                 Interaktives Menü
		  ./scripts/vereinsheim <command>       Direkt ausführen

		${BOLD}── ENTWICKLUNGSUMGEBUNG${RESET} ${DIM}(frische Workstation arbeitsfähig machen)${RESET}
		  ${GREEN}dev-setup${RESET}             Toolchain + codegraph + Dev-DB + .env + Schema  ${DIM}(idempotent)${RESET}

		${BOLD}── RELEASE-WORKFLOW${RESET} ${DIM}(lokal → VPS, braucht .vereinsheim.local)${RESET}
		  ${GREEN}local-setup${RESET}           Einmalig: VPS-Verbindung konfigurieren
		  ${GREEN}build${RESET}                 Beide Apps bauen + nach Docker Hub pushen
		  ${GREEN}release${RESET}               build + ssh-Deploy in einem Schritt
		  ${GREEN}ssh${RESET}                   Shell auf dem VPS
		  ${GREEN}remote${RESET} <cmd>          Befehl auf dem VPS via SSH
		  ${GREEN}upload${RESET} <datei> [...]  Datei(en) → VPS ~/migration/
		  ${GREEN}download${RESET} [datei]      Backup ← VPS  (ohne Arg: Liste)

		${BOLD}── LOKALE TESTUMGEBUNG${RESET} ${DIM}(braucht zusätzlich .env.local)${RESET}
		  ${GREEN}local-build${RESET}               Alle 4 Images lokal bauen (kein Push, native Plattform)
		  ${GREEN}local-pull${RESET}                Backups + Image-Tags vom VPS holen → ./backups/
		  ${GREEN}local-up${RESET}                  Lokalen Stack starten (vorhandene Volumes)
		  ${GREEN}local-up --restore${RESET}         Volumes löschen + aus ./backups/ neu laden
		  ${GREEN}local-down${RESET}                 Stack stoppen
		  ${GREEN}local-down --volumes${RESET}       Stack stoppen + alle Volumes löschen

		${BOLD}── HOST-DEV-DATENBANK${RESET} ${DIM}(docker-compose.dev.yml, für pnpm dev)${RESET}
		  ${GREEN}dev-restore${RESET} [app]         Prod-Dump aus ./backups/ → Dev-DB (Default: beide Apps)

		${BOLD}── VPS-OPERATIONEN${RESET} ${DIM}(auf dem Server, nutzt .env)${RESET}
		  ${GREEN}status${RESET}                Services, Volumes, Backups, .env, Cron
		  ${GREEN}deploy${RESET}                Pre-Backup + Pull + Up
		  ${GREEN}rollback${RESET}              Auf vorherigen Deploy zurück (aus deploy-history.log)
		  ${GREEN}backup${RESET}                Backup manuell erstellen
		  ${GREEN}restore${RESET}               Interaktiver Restore aus Backup
		  ${GREEN}logs${RESET} [service]        Logs folgen (Default: Apps + caddy)
		  ${GREEN}psql${RESET} <app>            DB-Shell (ringwerk | treffsicher)
		  ${GREEN}migrations${RESET} <app>      Migration-Status + Recovery
		  ${GREEN}shell${RESET} <service>       Bash-Shell im Container
		  ${GREEN}setup${RESET}                 .env-Wizard (Secrets generieren, validieren)
		  ${GREEN}env-check${RESET}             .env auf Vollständigkeit prüfen
		  ${GREEN}cron${RESET}                  Backup-Cron installieren/prüfen
		  ${GREEN}up${RESET} / ${GREEN}down${RESET} / ${GREEN}restart${RESET} <svc>  Service-Kontrolle

		${BOLD}TIPS${RESET}
		  ${YELLOW}vereinsheim release${RESET}            Standard-Release von der lokalen Maschine
		  ${YELLOW}vereinsheim remote status${RESET}      VPS-Stand ohne Login
		  ${YELLOW}SKIP_BACKUP=1 vereinsheim deploy${RESET}  Deploy ohne Pre-Backup
	EOF
}

# ============================================================
# Local-side commands
# ============================================================

# ---------- dev-setup ----------
# Dünner Wrapper auf scripts/bootstrap-dev.sh: macht eine frische Workstation
# arbeitsfähig (Toolchain, codegraph, Dev-DB, .env, Schema). Bewusst OHNE
# require_local_config — dev-setup läuft auf frischem Clone, bevor die
# VPS-Verbindung (local-setup) überhaupt existiert.
cmd_dev_setup() {
	exec "$SCRIPT_DIR/bootstrap-dev.sh" "$@"
}

# ---------- local-setup ----------
cmd_local_setup() {
	echo "${BOLD}=== local-setup ===${RESET}"
	echo "  Schreibt .vereinsheim.local mit lokaler Konfiguration"
	echo "  (VPS-Host, Repo-Pfad auf VPS, Docker-Hub-User)."
	echo

	if [[ -f "$LOCAL_CONFIG" ]]; then
		warn ".vereinsheim.local existiert bereits."
		load_local_config
		echo "  Aktuell:"
		echo "    VPS_HOST       = ${VPS_HOST:-(leer)}"
		echo "    VPS_REPO_PATH  = ${VPS_REPO_PATH:-(leer)}"
		echo "    DOCKER_USER    = ${DOCKER_USER:-(leer)}"
		echo
		confirm "Überschreiben?" || {
			info "Abgebrochen."
			return
		}
	fi

	local vps_host vps_repo docker_user
	vps_host="$(ask 'SSH-Ziel des VPS (z.B. deploy@vps.example.com)' "${VPS_HOST:-deploy@}")"
	vps_repo="$(ask 'Repo-Pfad auf dem VPS' "${VPS_REPO_PATH:-~/vereinsheim}")"
	docker_user="$(ask 'Docker-Hub-User' "${DOCKER_USER:-cyke}")"

	cat >"$LOCAL_CONFIG" <<-EOF
		# vereinsheim — lokale Konfiguration
		# Generiert am $(date -Iseconds). Wird von vereinsheim build/release/ssh/remote gelesen.
		# In .gitignore — wird nie committet.
		VPS_HOST=$vps_host
		VPS_REPO_PATH=$vps_repo
		DOCKER_USER=$docker_user
	EOF
	chmod 600 "$LOCAL_CONFIG"
	ok ".vereinsheim.local geschrieben."
	echo
	info "Test mit:    ./scripts/vereinsheim ssh"
	info "Erster Build:    ./scripts/vereinsheim build"
	info "Volles Release:  ./scripts/vereinsheim release"
}

# ---------- local-build ----------
# Baut alle 4 Images lokal aus dem Monorepo (--load, kein Push, native Plattform)
# via build-and-push.sh im PUSH=0-Modus. Uncommittete Änderungen sind erlaubt —
# der Subcommand ist explizit für lokale Testbuilds gedacht.
cmd_local_build() {
	require_local_config
	require_docker
	echo "${BOLD}=== local-build ===${RESET}"
	echo "  Baut alle 4 Images lokal (--load, kein Push) aus dem Monorepo (turbo prune)."
	echo "  Uncommittete Änderungen sind erlaubt — nur für lokale Tests."
	echo "  Docker-User : ${DOCKER_USER}"
	echo
	export DOCKER_USER
	PUSH=0 "$SCRIPT_DIR/build-and-push.sh"
	echo
	info "Stack starten:  ./scripts/vereinsheim local-up"
}

# ---------- build ----------
cmd_build() {
	require_local_config
	info "Build + Push beider Apps (target=runner und target=migrator) als $DOCKER_USER"
	export DOCKER_USER
	exec "$SCRIPT_DIR/build-and-push.sh" "$@"
}

# ---------- release ----------
cmd_release() {
	require_local_config
	info "Release: build → push → SSH-Deploy auf $VPS_HOST"
	echo
	confirm "Starten?" Y || {
		info "Abgebrochen."
		return
	}
	export DOCKER_USER
	"$SCRIPT_DIR/build-and-push.sh"
	echo
	info "Triggere Deploy auf $VPS_HOST …"
	# shellcheck disable=SC2029
	ssh -t "$VPS_HOST" "cd $VPS_REPO_PATH && ./scripts/vereinsheim deploy"
}

# ---------- ssh ----------
cmd_ssh() {
	require_local_config
	exec ssh -t "$VPS_HOST" "cd $VPS_REPO_PATH && exec \$SHELL -l"
}

# ---------- remote ----------
cmd_remote() {
	require_local_config
	if [[ $# -eq 0 ]]; then
		err "Aufruf: vereinsheim remote <subcommand> [args]"
		echo "  Beispiel: vereinsheim remote status"
		echo "            vereinsheim remote logs caddy"
		exit 1
	fi
	# shellcheck disable=SC2029
	exec ssh -t "$VPS_HOST" "cd $VPS_REPO_PATH && ./scripts/vereinsheim $*"
}

# ---------- upload ----------
cmd_upload() {
	require_local_config
	if [[ $# -eq 0 ]]; then
		err "Aufruf: vereinsheim upload <datei> [datei2 ...]"
		echo "  Beispiel: vereinsheim upload ringwerk-2026-05-11.dump uploads-ringwerk-2026-05-11.tar.gz"
		exit 1
	fi
	for f in "$@"; do
		[[ -f "$f" ]] || { err "Datei nicht gefunden: $f"; exit 1; }
	done
	info "Erstelle ~/migration/ auf $VPS_HOST …"
	ssh "$VPS_HOST" "mkdir -p ~/migration"
	info "Übertrage $# Datei(en) nach $VPS_HOST:~/migration/ …"
	scp "$@" "$VPS_HOST:~/migration/"
	ok "Übertragen. Aktueller Inhalt von ~/migration/:"
	ssh "$VPS_HOST" "ls -lh ~/migration/ 2>/dev/null | grep -E '\\.dump|\\.tar\\.gz' || echo '  (leer)'"
}

# ---------- download ----------
cmd_download() {
	require_local_config
	if [[ $# -eq 0 ]]; then
		info "Backups auf $VPS_HOST"
		hr
		echo "  ${BOLD}/var/backups/vereinsheim/${RESET}"
		ssh "$VPS_HOST" \
			"ls -lht /var/backups/vereinsheim/ 2>/dev/null \
			 | grep -E '\\.dump|\\.tar\\.gz' | head -20 \
			 || echo '  (keine)'" | sed 's/^/  /'
		echo
		echo "  ${BOLD}~/migration/${RESET}"
		ssh "$VPS_HOST" \
			"ls -lht ~/migration/ 2>/dev/null \
			 | grep -E '\\.dump|\\.tar\\.gz' | head -10 \
			 || echo '  (keine)'" | sed 's/^/  /'
		echo
		info "Herunterladen mit:  vereinsheim download <dateiname> [zielverzeichnis]"
		return
	fi
	local filename="$1"
	local target="${2:-.}"
	local remote_path
	remote_path=$(ssh "$VPS_HOST" "
		if [[ -f /var/backups/vereinsheim/$filename ]]; then
			echo /var/backups/vereinsheim/$filename
		elif [[ -f ~/migration/$filename ]]; then
			echo ~/migration/$filename
		fi
	")
	if [[ -z "$remote_path" ]]; then
		err "Datei nicht gefunden auf VPS: $filename"
		echo "  Gesucht in /var/backups/vereinsheim/ und ~/migration/"
		echo "  Liste anzeigen mit:  ./scripts/vereinsheim download"
		exit 1
	fi
	info "Lade $remote_path von $VPS_HOST …"
	scp "$VPS_HOST:$remote_path" "$target/"
	ok "Heruntergeladen: ${target%/}/$(basename "$remote_path")"
}

cmd_local_pull() {
	require_local_config
	require_docker

	info "=== local-pull: Backups + Image-Tags vom VPS holen ==="
	mkdir -p "$LOCAL_BACKUP_DIR"

	# Neueste Backup-Dateien auf VPS ermitteln
	info "Suche neueste Backups auf $VPS_HOST …"
	local latest_ringwerk latest_treffsicher latest_uploads
	latest_ringwerk=$(ssh "$VPS_HOST" \
		"ls -t /var/backups/vereinsheim/ringwerk-*.dump 2>/dev/null | head -1")
	latest_treffsicher=$(ssh "$VPS_HOST" \
		"ls -t /var/backups/vereinsheim/treffsicher-*.dump 2>/dev/null | head -1")
	latest_uploads=$(ssh "$VPS_HOST" \
		"ls -t /var/backups/vereinsheim/uploads-treffsicher-*.tar.gz 2>/dev/null | head -1")

	[[ -z "$latest_ringwerk" ]] && { err "Kein Ringwerk-Dump auf VPS gefunden."; exit 1; }
	[[ -z "$latest_treffsicher" ]] && { err "Kein Treffsicher-Dump auf VPS gefunden."; exit 1; }
	[[ -z "$latest_uploads" ]] && warn "Kein Uploads-Tar für Treffsicher gefunden — wird übersprungen."

	echo "  Ringwerk dump:    $(basename "$latest_ringwerk")"
	echo "  Treffsicher dump: $(basename "$latest_treffsicher")"
	[[ -n "$latest_uploads" ]] && echo "  Uploads tar:      $(basename "$latest_uploads")"
	echo

	# Herunterladen (nur wenn lokal noch nicht vorhanden)
	local files_to_download=("$latest_ringwerk" "$latest_treffsicher")
	[[ -n "$latest_uploads" ]] && files_to_download+=("$latest_uploads")

	for remote_path in "${files_to_download[@]}"; do
		local filename
		filename="$(basename "$remote_path")"
		local local_path="$LOCAL_BACKUP_DIR/$filename"
		if [[ -f "$local_path" ]]; then
			ok "Bereits vorhanden: $filename (übersprungen)"
		else
			info "Lade $filename …"
			scp "$VPS_HOST:$remote_path" "$local_path"
			ok "Heruntergeladen: $filename"
		fi
	done

	# Image-Tags aus VPS .env lesen
	info "Lese Image-Tags aus VPS .env …"
	local vps_env_vars
	vps_env_vars=$(ssh "$VPS_HOST" \
		"grep -E '^(DOCKER_USER|RINGWERK_TAG|RINGWERK_MIGRATOR_TAG|TREFFSICHER_TAG|TREFFSICHER_MIGRATOR_TAG)=' \
		 \"$VPS_REPO_PATH/.env\" 2>/dev/null || true")

	# .env.local erstellen falls noch nicht vorhanden
	if [[ ! -f "$LOCAL_ENV_FILE" ]]; then
		info "Erstelle .env.local mit lokalen Defaults …"
		_write_default_local_env
		ok ".env.local erstellt."
		warn "Bitte .env.local prüfen — App-Secrets sind lokale Platzhalter."
	fi

	# Image-Tags in .env.local aktualisieren
	if [[ -n "$vps_env_vars" ]]; then
		while IFS='=' read -r key value; do
			[[ -z "$key" ]] && continue
			if grep -q "^${key}=" "$LOCAL_ENV_FILE"; then
				sed -i '' "s|^${key}=.*|${key}=${value}|" "$LOCAL_ENV_FILE"
			else
				echo "${key}=${value}" >> "$LOCAL_ENV_FILE"
			fi
		done <<< "$vps_env_vars"
		ok "Image-Tags in .env.local aktualisiert."
	else
		warn "Konnte Image-Tags nicht von VPS lesen — behalte bestehende Werte."
	fi

	echo
	ok "local-pull abgeschlossen."
	echo "  Backups in: $LOCAL_BACKUP_DIR/"
	ls -lh "$LOCAL_BACKUP_DIR/"*.dump "$LOCAL_BACKUP_DIR/"*.tar.gz 2>/dev/null \
		| awk '{printf "    %-45s %s\n", $NF, $5}' || true
	echo
	info "Nächste Schritte:"
	echo "  Mit Produktionsdaten starten:  ./scripts/vereinsheim local-up --restore"
	echo "  Vorhandene Volumes nutzen:     ./scripts/vereinsheim local-up"
}

_write_default_local_env() {
	cat > "$LOCAL_ENV_FILE" <<-EOF
		# vereinsheim — lokale Testumgebung
		# Erstellt von ./scripts/vereinsheim local-pull.
		# Gitignored — wird nie committet.
		# App-Secrets sind lokale Platzhalter; nach Restore sind VPS-Sessions ungültig.

		# === Docker Images (werden von local-pull mit VPS-Tags aktualisiert) ===
		DOCKER_USER=${DOCKER_USER}
		RINGWERK_TAG=latest
		RINGWERK_MIGRATOR_TAG=latest-migrator
		TREFFSICHER_TAG=latest
		TREFFSICHER_MIGRATOR_TAG=latest-migrator

		# === Lokale Domain-Platzhalter (verhindert compose-Warnungen) ===
		DOMAIN=localhost
		RINGWERK_HOST=localhost
		TREFFSICHER_HOST=localhost
		ACME_EMAIL=local@localhost

		# === Postgres (lokale Platzhalter — kein Produktions-Wert!) ===
		POSTGRES_PASSWORD=localdev
		RINGWERK_DB_PASSWORD=localdev
		TREFFSICHER_DB_PASSWORD=localdev

		# === Ringwerk (lokale Platzhalter) ===
		RINGWERK_NEXTAUTH_SECRET=local-dev-secret-ringwerk-00000000000000
		RINGWERK_SEED_ADMIN_EMAIL=admin@localhost
		RINGWERK_SEED_ADMIN_PASSWORD=localdevpassword

		# === Treffsicher (lokale Platzhalter) ===
		TREFFSICHER_NEXTAUTH_SECRET=local-dev-secret-treffsicher-000000000
		TREFFSICHER_ADMIN_EMAIL=admin@localhost
		TREFFSICHER_ADMIN_PASSWORD=localdevpassword

		# === Gemeinsam ===
		DISPLAY_TIME_ZONE=Europe/Berlin
	EOF
	chmod 600 "$LOCAL_ENV_FILE"
}

_local_up_with_restore() {
	# Neueste lokale Dumps suchen
	local dump_ringwerk dump_treffsicher uploads_treffsicher
	dump_ringwerk=$(ls -t "$LOCAL_BACKUP_DIR"/ringwerk-*.dump 2>/dev/null | head -1)
	dump_treffsicher=$(ls -t "$LOCAL_BACKUP_DIR"/treffsicher-*.dump 2>/dev/null | head -1)
	uploads_treffsicher=$(ls -t "$LOCAL_BACKUP_DIR"/uploads-treffsicher-*.tar.gz 2>/dev/null | head -1)

	if [[ -z "$dump_ringwerk" || -z "$dump_treffsicher" ]]; then
		err "Keine lokalen Dumps in $LOCAL_BACKUP_DIR/ — bitte zuerst ausführen:"
		echo "    ./scripts/vereinsheim local-pull"
		exit 1
	fi

	echo "  Dumps für Restore:"
	echo "    Ringwerk:    $(basename "$dump_ringwerk")"
	echo "    Treffsicher: $(basename "$dump_treffsicher")"
	if [[ -n "$uploads_treffsicher" ]]; then
		echo "    Uploads:     $(basename "$uploads_treffsicher")"
	else
		warn "Kein Uploads-Tar gefunden — Treffsicher-Uploads werden nicht restored."
	fi
	echo

	warn "Dies löscht alle lokalen Volumes und lädt Produktionsdaten!"
	confirm "Wirklich fortfahren?" || { info "Abgebrochen."; return; }

	# 1. Sauberer Slate
	info "Stoppe Stack und lösche Volumes …"
	local_compose down -v 2>/dev/null || true

	# 2. Nur DB starten, warten bis healthy
	info "Starte DB …"
	local_compose up -d db

	info "Warte auf DB-Healthcheck …"
	local max_attempts="${DB_STARTUP_TIMEOUT:-30}"
	local attempts=0
	while [[ $attempts -lt $max_attempts ]]; do
		if local_compose exec -T db pg_isready -U postgres >/dev/null 2>&1; then
			break
		fi
		attempts=$((attempts + 1))
		sleep 2
	done
	if [[ $attempts -ge $max_attempts ]]; then
		err "DB nicht healthy nach $((max_attempts * 2)) Sekunden (DB_STARTUP_TIMEOUT=$max_attempts)."
		exit 1
	fi
	ok "DB healthy."

	# 3. Restore Ringwerk
	info "Restore Ringwerk …"
	local dump_abs
	dump_abs="$(cd "$(dirname "$dump_ringwerk")" && pwd)/$(basename "$dump_ringwerk")"
	local_compose cp "$dump_abs" db:/tmp/restore.dump
	local_compose exec -T db pg_restore \
		-U postgres \
		-d ringwerk \
		--clean --if-exists \
		--no-owner \
		--role=ringwerk \
		/tmp/restore.dump
	local_compose exec -T db rm -f /tmp/restore.dump
	ok "Ringwerk restored."

	# 4. Restore Treffsicher
	info "Restore Treffsicher …"
	dump_abs="$(cd "$(dirname "$dump_treffsicher")" && pwd)/$(basename "$dump_treffsicher")"
	local_compose cp "$dump_abs" db:/tmp/restore.dump
	local_compose exec -T db pg_restore \
		-U postgres \
		-d treffsicher \
		--clean --if-exists \
		--no-owner \
		--role=treffsicher \
		/tmp/restore.dump
	local_compose exec -T db rm -f /tmp/restore.dump
	ok "Treffsicher restored."

	# 5. Uploads-Tar (optional)
	if [[ -n "$uploads_treffsicher" ]]; then
		info "Restore Treffsicher-Uploads …"
		local uploads_abs
		uploads_abs="$(cd "$(dirname "$uploads_treffsicher")" && pwd)/$(basename "$uploads_treffsicher")"
		docker run --rm \
			-v "vereinsheim_uploads_treffsicher:/dst" \
			-v "${uploads_abs}:/tmp/uploads.tar.gz:ro" \
			alpine sh -c 'cd /dst && tar xzf /tmp/uploads.tar.gz'
		ok "Uploads restored."
	fi

	# 6. Alle Services starten
	info "Starte alle Services …"
	local_compose up -d
}

_local_print_urls() {
	echo
	ok "Lokale Umgebung läuft:"
	echo "  Ringwerk:    http://localhost:3000"
	echo "  Treffsicher: http://localhost:3001"
	echo "  DB (psql):   localhost:5432"
	echo
	info "Stoppen:           ./scripts/vereinsheim local-down"
	info "Stoppen + Volumes: ./scripts/vereinsheim local-down --volumes"
}

cmd_local_up() {
	require_local_config
	require_local_env
	require_docker

	local do_restore=false
	[[ "${1:-}" == "--restore" ]] && do_restore=true

	if [[ ! -f "$LOCAL_COMPOSE_FILE" ]]; then
		err "compose.local.yml nicht gefunden: $LOCAL_COMPOSE_FILE"
		exit 1
	fi

	stop_dev_db_if_running

	if $do_restore; then
		info "=== local-up --restore: clean slate mit Produktionsdaten ==="
		_local_up_with_restore
	else
		info "Starte lokalen Stack (vorhandene Volumes) …"
		local_compose up -d
	fi
	_local_print_urls
}

cmd_local_down() {
	require_local_config
	require_local_env
	require_docker

	local remove_volumes=false
	[[ "${1:-}" == "--volumes" ]] && remove_volumes=true

	if $remove_volumes; then
		warn "Stoppt Stack UND löscht alle lokalen Volumes (postgres_data, uploads, …)"
		confirm "Sicher?" || { info "Abgebrochen."; return; }
		local_compose down -v
		ok "Stack gestoppt, Volumes gelöscht."
	else
		local_compose down
		ok "Stack gestoppt."
	fi
}

# ---------- dev-restore ----------
# Importiert die neuesten Prod-Dumps aus ./backups/ in die lokale DEV-Datenbank
# (docker-compose.dev.yml). Nur DB — keine Uploads, kein SSH. Pendant zu
# `local-up --restore`, aber für die Host-Dev-Umgebung (`pnpm dev`) statt den
# Prod-Stack-Simulator. Quelle der Dumps ist ./backups/ (befüllt von local-pull).
cmd_dev_restore() {
	require_docker

	# Ziel-App(s): optionales Argument schränkt auf eine App ein, sonst beide.
	local apps
	case "${1:-}" in
	"") apps=(ringwerk treffsicher) ;;
	ringwerk | treffsicher) apps=("$1") ;;
	*)
		err "Aufruf: vereinsheim dev-restore [ringwerk|treffsicher]"
		return 1
		;;
	esac

	if [[ ! -d "$LOCAL_BACKUP_DIR" ]]; then
		err "Kein Backup-Ordner: $LOCAL_BACKUP_DIR"
		echo "  → Erst Backups vom VPS holen:  ./scripts/vereinsheim local-pull"
		return 1
	fi

	# Neuesten Dump je Ziel-App ermitteln; fehlende überspringen (|| true, damit
	# der Leerfall nicht via set -e abbricht, sondern der Check unten greift).
	local restore_apps=() restore_dumps=()
	local app dump
	for app in "${apps[@]}"; do
		dump=$(ls -t "$LOCAL_BACKUP_DIR/${app}"-*.dump 2>/dev/null | head -1) || true
		if [[ -z "$dump" ]]; then
			warn "Kein Dump für $app in $LOCAL_BACKUP_DIR/ gefunden — übersprungen."
			continue
		fi
		restore_apps+=("$app")
		restore_dumps+=("$dump")
	done

	if [[ ${#restore_apps[@]} -eq 0 ]]; then
		err "Keine passenden Dumps in $LOCAL_BACKUP_DIR/ gefunden."
		echo "  → Erst Backups vom VPS holen:  ./scripts/vereinsheim local-pull"
		return 1
	fi

	echo "${BOLD}=== dev-restore ===${RESET}"
	echo "  Ziel: lokale Dev-DB (docker-compose.dev.yml, Projekt vereinsheim-dev)"
	local i
	for i in "${!restore_apps[@]}"; do
		printf "    %-12s ← %s\n" "${restore_apps[i]}" "$(basename "${restore_dumps[i]}")"
	done
	echo
	warn "Dies überschreibt die Dev-Datenbank(en) ${restore_apps[*]} mit Produktionsdaten."
	confirm "Wirklich fortfahren?" || {
		info "Abgebrochen."
		return
	}

	# DB hochfahren + auf healthy warten. Beim Erststart (leeres Volume) legt
	# dev/db-init die Rollen ringwerk/treffsicher an — nötig für --role beim Restore.
	info "Starte Dev-DB …"
	dev_compose up -d db
	info "Warte auf DB-Healthcheck …"
	local max_attempts="${DB_STARTUP_TIMEOUT:-30}" attempts=0
	while [[ $attempts -lt $max_attempts ]]; do
		if dev_compose exec -T db pg_isready -U postgres >/dev/null 2>&1; then
			break
		fi
		attempts=$((attempts + 1))
		sleep 2
	done
	if [[ $attempts -ge $max_attempts ]]; then
		err "Dev-DB nicht healthy nach $((max_attempts * 2)) s (DB_STARTUP_TIMEOUT=$max_attempts)."
		return 1
	fi
	ok "Dev-DB healthy."

	# Pro App restoren — gleiche Flags wie der Prod-Restore (restore.sh):
	# --clean --if-exists --no-owner --role=<app>.
	for i in "${!restore_apps[@]}"; do
		app="${restore_apps[i]}"
		dump="${restore_dumps[i]}"
		info "Restore $app aus $(basename "$dump") …"
		dev_compose cp "$dump" db:/tmp/restore.dump
		dev_compose exec -T db pg_restore \
			-U postgres \
			-d "$app" \
			--clean --if-exists \
			--no-owner \
			--role="$app" \
			/tmp/restore.dump
		dev_compose exec -T db rm -f /tmp/restore.dump
		ok "$app restored."
	done

	echo
	ok "dev-restore abgeschlossen."
	info "Nächste Schritte:"
	echo "  • Falls lokale Migrationen neuer sind als der Dump-Stand:"
	echo "      pnpm --filter <app> exec prisma migrate deploy"
	echo "  • Login mit einem Prod-Account (alte Sessions sind lokal ungültig)."
	echo "  • Dev starten:  pnpm dev"
}

# ============================================================
# VPS-side commands
# ============================================================

# ---------- setup ----------
cmd_setup() {
	echo "${BOLD}=== vereinsheim setup ===${RESET}"
	echo "  Legt .env an oder bearbeitet bestehende Werte."
	echo

	if [[ -f "$ENV_FILE" ]]; then
		warn ".env existiert bereits."
		echo "  1) Komplett neu erstellen (alte wird gesichert als .env.bak)"
		echo "  2) Einzelne Werte bearbeiten"
		echo "  3) Abbrechen"
		local choice
		read -r -p "  Wahl: " choice
		case "$choice" in
		1)
			cp "$ENV_FILE" "$ENV_FILE.bak"
			ok "Backup nach .env.bak"
			;;
		2)
			setup_edit_single
			return
			;;
		*)
			info "Abgebrochen."
			return
			;;
		esac
	fi

	hr
	info "Domain & TLS"
	local DOMAIN RINGWERK_HOST TREFFSICHER_HOST ACME_EMAIL
	DOMAIN="$(ask_validated 'Basis-Domain (z.B. example.com)' is_hostname)"
	RINGWERK_HOST="$(ask_validated 'Subdomain für Ringwerk' is_hostname "ringwerk.$DOMAIN")"
	TREFFSICHER_HOST="$(ask_validated 'Subdomain für Treffsicher' is_hostname "treffsicher.$DOMAIN")"
	ACME_EMAIL="$(ask_validated 'E-Mail für Let'\''s-Encrypt-Benachrichtigungen' is_email)"

	hr
	info "Docker Hub"
	local DOCKER_USER
	DOCKER_USER="$(ask 'Docker-Hub-User' "cyke")"

	hr
	info "Postgres-Passwörter (Enter = generieren)"
	local POSTGRES_PASSWORD RINGWERK_DB_PASSWORD TREFFSICHER_DB_PASSWORD
	POSTGRES_PASSWORD="$(ask_secret 'Postgres-Superuser-Passwort')"
	RINGWERK_DB_PASSWORD="$(ask_secret 'Ringwerk-DB-User-Passwort')"
	TREFFSICHER_DB_PASSWORD="$(ask_secret 'Treffsicher-DB-User-Passwort')"

	hr
	info "Ringwerk"
	local RINGWERK_NEXTAUTH_SECRET RINGWERK_SEED_ADMIN_EMAIL RINGWERK_SEED_ADMIN_PASSWORD
	RINGWERK_NEXTAUTH_SECRET="$(ask_secret 'NEXTAUTH_SECRET (mind. 32 Zeichen)' 48)"
	RINGWERK_SEED_ADMIN_EMAIL="$(ask_validated 'Initial-Admin E-Mail' is_email "admin@${DOMAIN}")"
	make_min_validator 12
	RINGWERK_SEED_ADMIN_PASSWORD="$(ask_validated 'Initial-Admin Passwort (mind. 12 Zeichen)' _min_12)"

	hr
	info "Treffsicher"
	local TREFFSICHER_NEXTAUTH_SECRET TREFFSICHER_ADMIN_EMAIL TREFFSICHER_ADMIN_PASSWORD
	TREFFSICHER_NEXTAUTH_SECRET="$(ask_secret 'NEXTAUTH_SECRET (mind. 32 Zeichen)' 48)"
	TREFFSICHER_ADMIN_EMAIL="$(ask_validated 'Initial-Admin E-Mail' is_email "admin@${DOMAIN}")"
	TREFFSICHER_ADMIN_PASSWORD="$(ask_validated 'Initial-Admin Passwort (mind. 12 Zeichen)' _min_12)"

	hr
	info "Sonstiges"
	local DISPLAY_TIME_ZONE
	DISPLAY_TIME_ZONE="$(ask 'Anzeige-Zeitzone' 'Europe/Berlin')"

	hr
	info "Zusammenfassung"
	cat <<-EOF
		  Domain                    : $DOMAIN
		  Ringwerk Host             : $RINGWERK_HOST
		  Treffsicher Host          : $TREFFSICHER_HOST
		  ACME-E-Mail               : $ACME_EMAIL
		  Docker-Hub-User           : $DOCKER_USER
		  Image-Tags                : latest / latest-migrator
		  Postgres-Passwort         : ${DIM}(redacted, ${#POSTGRES_PASSWORD} chars)${RESET}
		  Ringwerk-DB-Passwort      : ${DIM}(redacted, ${#RINGWERK_DB_PASSWORD} chars)${RESET}
		  Treffsicher-DB-Passwort   : ${DIM}(redacted, ${#TREFFSICHER_DB_PASSWORD} chars)${RESET}
		  Ringwerk NEXTAUTH_SECRET  : ${DIM}(${#RINGWERK_NEXTAUTH_SECRET} chars)${RESET}
		  Ringwerk Seed-Admin       : $RINGWERK_SEED_ADMIN_EMAIL
		  Treffsicher NEXTAUTH      : ${DIM}(${#TREFFSICHER_NEXTAUTH_SECRET} chars)${RESET}
		  Treffsicher Admin         : $TREFFSICHER_ADMIN_EMAIL
		  Zeitzone                  : $DISPLAY_TIME_ZONE
	EOF
	echo
	confirm ".env schreiben?" Y || {
		info "Abgebrochen — nichts geschrieben."
		return 1
	}

	cat >"$ENV_FILE" <<-EOF
		# Generiert von ./scripts/vereinsheim setup am $(date -Iseconds)
		# === Domain & TLS ===
		DOMAIN=$DOMAIN
		RINGWERK_HOST=$RINGWERK_HOST
		TREFFSICHER_HOST=$TREFFSICHER_HOST
		ACME_EMAIL=$ACME_EMAIL

		# === Docker Images ===
		DOCKER_USER=$DOCKER_USER
		RINGWERK_TAG=latest
		RINGWERK_MIGRATOR_TAG=latest-migrator
		TREFFSICHER_TAG=latest
		TREFFSICHER_MIGRATOR_TAG=latest-migrator

		# === Postgres ===
		POSTGRES_PASSWORD=$POSTGRES_PASSWORD
		RINGWERK_DB_PASSWORD=$RINGWERK_DB_PASSWORD
		TREFFSICHER_DB_PASSWORD=$TREFFSICHER_DB_PASSWORD

		# === Ringwerk ===
		RINGWERK_NEXTAUTH_SECRET=$RINGWERK_NEXTAUTH_SECRET
		RINGWERK_SEED_ADMIN_EMAIL=$RINGWERK_SEED_ADMIN_EMAIL
		RINGWERK_SEED_ADMIN_PASSWORD=$RINGWERK_SEED_ADMIN_PASSWORD

		# === Treffsicher ===
		TREFFSICHER_NEXTAUTH_SECRET=$TREFFSICHER_NEXTAUTH_SECRET
		TREFFSICHER_ADMIN_EMAIL=$TREFFSICHER_ADMIN_EMAIL
		TREFFSICHER_ADMIN_PASSWORD=$TREFFSICHER_ADMIN_PASSWORD

		# === Beide gemeinsam ===
		DISPLAY_TIME_ZONE=$DISPLAY_TIME_ZONE
	EOF
	chmod 600 "$ENV_FILE"
	ok ".env geschrieben (chmod 600)."
	echo
	info "Nächste Schritte:"
	echo "  1) DNS-Einträge setzen (A-Record für $RINGWERK_HOST und $TREFFSICHER_HOST → diese VPS-IP)"
	echo "  2) Image-Build (lokal):  DOCKER_USER=$DOCKER_USER ./scripts/build-and-push.sh"
	echo "  3) Erster Deploy:        ./scripts/vereinsheim deploy"
	echo "  4) Backup-Cron:          ./scripts/vereinsheim cron"
}

setup_edit_single() {
	require_env
	echo
	info "Verfügbare Variablen:"
	mapfile -t keys < <(env_keys_from_example)
	local i=1
	for k in "${keys[@]}"; do
		printf "  %2d) %s\n" "$i" "$k"
		i=$((i + 1))
	done
	local choice key new_value
	read -r -p "  Nummer der zu ändernden Variable: " choice
	if ! [[ "$choice" =~ ^[0-9]+$ ]] || [[ "$choice" -lt 1 ]] || [[ "$choice" -gt ${#keys[@]} ]]; then
		err "Ungültige Auswahl."
		return 1
	fi
	key="${keys[$((choice - 1))]}"
	local current
	current="$(read_env_var "$key" || echo '')"
	echo "  Aktueller Wert: ${DIM}${current:-(leer)}${RESET}"
	read -r -p "  Neuer Wert (Enter = unverändert): " new_value
	if [[ -z "$new_value" ]]; then
		info "Keine Änderung."
		return
	fi
	write_env_var "$key" "$new_value"
	ok "$key aktualisiert."
	warn "Damit Änderungen wirksam werden:  ./scripts/vereinsheim deploy"
}

# ---------- env-check ----------
env_keys_from_file() {
	# All variable names assigned in .env (ignoring comments and blank lines)
	awk -F= '/^[[:space:]]*#/ { next } /^[A-Z][A-Z0-9_]*=/ { print $1 }' "$ENV_FILE"
}

cmd_env_check() {
	require_env
	local missing=() weak=() unknown=() ok_count=0
	while IFS= read -r key; do
		local val
		val="$(read_env_var "$key" || echo '')"
		if [[ -z "$val" ]]; then
			missing+=("$key")
			continue
		fi
		ok_count=$((ok_count + 1))
		case "$key" in
		*NEXTAUTH_SECRET)
			[[ ${#val} -lt 32 ]] && weak+=("$key (zu kurz: ${#val} chars, mind. 32 empfohlen)")
			;;
		*PASSWORD)
			[[ ${#val} -lt 12 ]] && weak+=("$key (zu kurz: ${#val} chars, mind. 12 empfohlen)")
			;;
		ACME_EMAIL | *_EMAIL)
			is_email "$val" || weak+=("$key (kein gültiges E-Mail-Format)")
			;;
		DOMAIN | *_HOST)
			is_hostname "$val" || weak+=("$key (kein gültiger Hostname)")
			;;
		esac
	done < <(env_keys_from_example)

	# Detect keys in .env that aren't in .env.example (typos, stale vars)
	local expected_keys
	expected_keys="$(env_keys_from_example)"
	while IFS= read -r key; do
		grep -qxF "$key" <<<"$expected_keys" || unknown+=("$key")
	done < <(env_keys_from_file)

	echo "${BOLD}=== env-check ===${RESET}"
	echo "  Datei: $ENV_FILE"
	echo "  Gesetzt: ${ok_count} / $(env_keys_from_example | wc -l | tr -d ' ')"
	if [[ ${#missing[@]} -gt 0 ]]; then
		err "Fehlend (${#missing[@]}):"
		printf '    - %s\n' "${missing[@]}"
	fi
	if [[ ${#weak[@]} -gt 0 ]]; then
		warn "Auffällig (${#weak[@]}):"
		printf '    - %s\n' "${weak[@]}"
	fi
	if [[ ${#unknown[@]} -gt 0 ]]; then
		warn "Unbekannt (${#unknown[@]}, evtl. Tippfehler oder veraltet):"
		printf '    - %s\n' "${unknown[@]}"
	fi
	if [[ ${#missing[@]} -eq 0 && ${#weak[@]} -eq 0 && ${#unknown[@]} -eq 0 ]]; then
		ok "Alles OK."
	fi
}

# ---------- status ----------
cmd_status() {
	echo "${BOLD}=== vereinsheim status ===${RESET}"
	echo "  Repo-Verzeichnis : $REPO_DIR"
	if [[ -d .git ]]; then
		echo "  Branch           : $(git rev-parse --abbrev-ref HEAD)"
		echo "  Letzter Commit   : $(git log -1 --format='%h %s')"
	fi
	if [[ -f "$ENV_FILE" ]]; then
		ok ".env vorhanden ($(stat -c%y "$ENV_FILE" 2>/dev/null || stat -f%Sm "$ENV_FILE"))"
	else
		warn ".env fehlt — bitte ./scripts/vereinsheim setup"
	fi

	hr
	if ! command -v docker >/dev/null 2>&1; then
		warn "docker nicht installiert — keine weiteren Checks möglich."
		return
	fi
	if ! docker info >/dev/null 2>&1; then
		warn "Docker daemon nicht erreichbar."
		return
	fi

	echo "${BOLD}Services${RESET}"
	if [[ -f "$ENV_FILE" ]]; then
		docker compose ps 2>/dev/null || warn "compose ps fehlgeschlagen"
	else
		warn "Ohne .env keine compose-Befehle möglich."
	fi

	hr
	echo "${BOLD}Volumes${RESET}"
	for v in postgres_data uploads_treffsicher caddy_data caddy_config; do
		local full="vereinsheim_$v"
		if docker volume inspect "$full" >/dev/null 2>&1; then
			# Größe via du im alpine-Container abfragen
			local size
			size=$(docker run --rm -v "$full:/d:ro" alpine du -sh /d 2>/dev/null | awk '{print $1}')
			printf "  %-26s %s\n" "$v" "${size:-?}"
		else
			printf "  %-26s ${DIM}(noch nicht angelegt)${RESET}\n" "$v"
		fi
	done

	hr
	echo "${BOLD}Backups${RESET}  (${BACKUP_DIR_DEFAULT})"
	if [[ -d "$BACKUP_DIR_DEFAULT" ]]; then
		local count
		count=$(find "$BACKUP_DIR_DEFAULT" -maxdepth 1 -type f \( -name '*.dump' -o -name '*.tar.gz' \) | wc -l | tr -d ' ')
		echo "  Dateien insgesamt : $count"
		echo "  Belegt            : $(du -sh "$BACKUP_DIR_DEFAULT" 2>/dev/null | awk '{print $1}')"
		echo "  Letzte 4:"
		find "$BACKUP_DIR_DEFAULT" -maxdepth 1 -type f \( -name '*.dump' -o -name '*.tar.gz' \) -printf '%TY-%Tm-%Td %TH:%TM  %s  %f\n' 2>/dev/null |
			sort -r | head -4 | awk '{ printf "    %s %s  %5.1f MB  %s\n", $1, $2, $3/1024/1024, $4 }' ||
			ls -lht "$BACKUP_DIR_DEFAULT"/*.dump 2>/dev/null | head -4 || true
	else
		warn "Backup-Verzeichnis nicht vorhanden (Cron ggf. noch nicht eingerichtet)"
	fi

	hr
	echo "${BOLD}Cron${RESET}"
	if crontab -l 2>/dev/null | grep -q 'vereinsheim/scripts/backup.sh'; then
		ok "Backup-Cron registriert"
		crontab -l 2>/dev/null | grep 'vereinsheim/scripts/backup.sh' | sed 's/^/    /'
	else
		warn "Kein Backup-Cron — installieren mit:  ./scripts/vereinsheim cron"
	fi
}

# ---------- deploy ----------
_check_image_tags() {
	# Verifies that all four image-tag vars are set. Returns:
	#   0 — alles gesetzt
	#   1 — keiner gesetzt (Erst-Deploy-Szenario, ruft Confirm auf)
	#   2 — gemischt (Asymmetrie, abort)
	local r_app r_mig t_app t_mig
	r_app="$(read_env_var RINGWERK_TAG || true)"
	r_mig="$(read_env_var RINGWERK_MIGRATOR_TAG || true)"
	t_app="$(read_env_var TREFFSICHER_TAG || true)"
	t_mig="$(read_env_var TREFFSICHER_MIGRATOR_TAG || true)"
	local set_count=0
	[[ -n "$r_app" ]] && set_count=$((set_count + 1))
	[[ -n "$r_mig" ]] && set_count=$((set_count + 1))
	[[ -n "$t_app" ]] && set_count=$((set_count + 1))
	[[ -n "$t_mig" ]] && set_count=$((set_count + 1))
	case "$set_count" in
	4) return 0 ;;
	0) return 1 ;;
	*) return 2 ;;
	esac
}

cmd_deploy() {
	require_env
	require_docker
	cmd_env_check
	echo
	local tag_state=0
	_check_image_tags || tag_state=$?
	case "$tag_state" in
	0) ;;
	1)
		warn "Keine Image-Tags in .env gepinnt — compose nutzt die Defaults aus compose.yml (\`:latest\`)."
		confirm "Trotzdem deployen?" N || {
			info "Abgebrochen."
			return
		}
		;;
	2)
		err "Image-Tags asymmetrisch gesetzt — alle vier (RINGWERK_TAG, RINGWERK_MIGRATOR_TAG, TREFFSICHER_TAG, TREFFSICHER_MIGRATOR_TAG) müssen entweder gemeinsam gesetzt oder gemeinsam leer sein."
		return 1
		;;
	esac
	confirm "Deploy jetzt starten?" Y || {
		info "Abgebrochen."
		return
	}
	exec "$SCRIPT_DIR/deploy.sh"
}

# ---------- rollback ----------
HISTORY_FILE="$REPO_DIR/logs/deploy-history.log"

_extract_tag() {
	# Parse "KEY=VALUE" pair from a history line.
	local key="$1" line="$2"
	awk -v k="$key" '{
		for (i = 1; i <= NF; i++) {
			if (index($i, k "=") == 1) {
				sub(/^[^=]*=/, "", $i)
				print $i
				exit
			}
		}
	}' <<<"$line"
}

_rollback_diff_line() {
	local key="$1" new="$2" current
	current="$(read_env_var "$key" || echo '')"
	if [[ "$current" == "$new" ]]; then
		printf "  %s: %s${DIM} (unverändert)${RESET}\n" "$key" "$new"
	else
		printf "  %s: ${DIM}%s${RESET} → ${BOLD}%s${RESET}\n" "$key" "${current:-(leer)}" "$new"
	fi
}

cmd_rollback() {
	require_env
	require_docker
	if [[ ! -f "$HISTORY_FILE" ]]; then
		err "Keine Deploy-History gefunden ($HISTORY_FILE)."
		info "Manueller Pfad: ./scripts/vereinsheim setup → einzelne Werte bearbeiten,"
		info "                dann SKIP_BACKUP=1 ./scripts/vereinsheim deploy"
		return 1
	fi

	mapfile -t entries < <(tac "$HISTORY_FILE" | head -5)
	if ((${#entries[@]} < 2)); then
		err "Nur ${#entries[@]} Deploy-Eintrag in History — kein Rollback-Ziel verfügbar."
		info "Erst ab dem zweiten Deploy ist ein Rollback möglich."
		return 1
	fi

	echo
	echo "${BOLD}Letzte Deployments${RESET}  ${DIM}(neueste oben, 1 = aktuell)${RESET}"
	local i=1
	for entry in "${entries[@]}"; do
		local ts r_app t_app
		ts="$(awk '{print $1}' <<<"$entry")"
		r_app="$(_extract_tag RINGWERK_TAG "$entry")"
		t_app="$(_extract_tag TREFFSICHER_TAG "$entry")"
		printf "  %d) %s   ringwerk=%s  treffsicher=%s\n" "$i" "$ts" "${r_app:-?}" "${t_app:-?}"
		i=$((i + 1))
	done

	echo
	local choice
	read -r -p "  Rollback-Ziel [2]: " choice
	choice="${choice:-2}"
	if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
		err "Ungültige Eingabe."
		return 1
	fi
	if ((choice < 1 || choice > ${#entries[@]})); then
		err "Außerhalb der Range (1..${#entries[@]})."
		return 1
	fi
	if ((choice == 1)); then
		warn "Eintrag 1 = aktueller Stand. Kein Rollback nötig."
		return 0
	fi

	local target="${entries[$((choice - 1))]}"
	local new_r_app new_r_mig new_t_app new_t_mig
	new_r_app="$(_extract_tag RINGWERK_TAG "$target")"
	new_r_mig="$(_extract_tag RINGWERK_MIGRATOR_TAG "$target")"
	new_t_app="$(_extract_tag TREFFSICHER_TAG "$target")"
	new_t_mig="$(_extract_tag TREFFSICHER_MIGRATOR_TAG "$target")"

	if [[ -z "$new_r_app" || -z "$new_r_mig" || -z "$new_t_app" || -z "$new_t_mig" ]]; then
		err "Eintrag $choice unvollständig — Tag fehlt. History-Datei manuell prüfen:"
		echo "  $HISTORY_FILE"
		return 1
	fi

	echo
	echo "${BOLD}Änderungen${RESET}"
	_rollback_diff_line RINGWERK_TAG "$new_r_app"
	_rollback_diff_line RINGWERK_MIGRATOR_TAG "$new_r_mig"
	_rollback_diff_line TREFFSICHER_TAG "$new_t_app"
	_rollback_diff_line TREFFSICHER_MIGRATOR_TAG "$new_t_mig"

	echo
	warn "Falls die fehlgeschlagene Version eine Migration enthielt, ist die DB"
	warn "jetzt im Schema-Stand der neueren Version. Reines Tag-Rollback genügt"
	warn "dann nicht — du brauchst zusätzlich:  ./scripts/vereinsheim restore"

	echo
	confirm "Tags in .env schreiben und neu deployen?" Y || {
		info "Abgebrochen."
		return
	}

	write_env_var RINGWERK_TAG "$new_r_app"
	write_env_var RINGWERK_MIGRATOR_TAG "$new_r_mig"
	write_env_var TREFFSICHER_TAG "$new_t_app"
	write_env_var TREFFSICHER_MIGRATOR_TAG "$new_t_mig"
	ok "Tags in .env aktualisiert."

	# Pre-Deploy-Backup überspringen: der Stand, der gleich überschrieben
	# wird, ist gerade der kaputte — wir wollen kein Backup davon.
	SKIP_BACKUP=1 exec "$SCRIPT_DIR/deploy.sh"
}

# ---------- backup ----------
cmd_backup() {
	require_env
	require_docker
	exec "$SCRIPT_DIR/backup.sh"
}

# ---------- restore ----------
cmd_restore() {
	require_env
	require_docker
	echo "${BOLD}=== restore ===${RESET}"
	echo "  Welche App?"
	echo "    1) ringwerk"
	echo "    2) treffsicher"
	local choice app
	read -r -p "  Wahl: " choice
	case "$choice" in
	1) app="ringwerk" ;;
	2) app="treffsicher" ;;
	*)
		err "Ungültig."
		return 1
		;;
	esac

	local backup_dir="${BACKUP_DIR:-$BACKUP_DIR_DEFAULT}"
	if [[ ! -d "$backup_dir" ]]; then
		err "Backup-Verzeichnis nicht gefunden: $backup_dir"
		return 1
	fi

	echo
	echo "  Verfügbare Dumps für $app (neueste zuerst):"
	mapfile -t dumps < <(find "$backup_dir" -maxdepth 1 -name "${app}-*.dump" -type f -print0 |
		xargs -0 -I {} stat -c '%Y %n' {} 2>/dev/null | sort -rn | awk '{print $2}')
	if [[ ${#dumps[@]} -eq 0 ]]; then
		err "Keine Dumps gefunden."
		return 1
	fi
	local i=1
	for d in "${dumps[@]:0:10}"; do
		local size
		size=$(du -sh "$d" 2>/dev/null | awk '{print $1}')
		printf "    %2d) %s  (%s)\n" "$i" "$(basename "$d")" "$size"
		i=$((i + 1))
	done
	local pick
	read -r -p "  Nummer: " pick
	if ! [[ "$pick" =~ ^[0-9]+$ ]] || [[ "$pick" -lt 1 ]] || [[ "$pick" -gt ${#dumps[@]} ]]; then
		err "Ungültige Auswahl."
		return 1
	fi
	local dump="${dumps[$((pick - 1))]}"

	# Passender Uploads-Tar?
	local stem
	stem="$(basename "$dump" .dump)"
	stem="${stem#${app}-}"
	local uploads="${backup_dir}/uploads-${app}-${stem}.tar.gz"
	if [[ -f "$uploads" ]]; then
		echo "  ${GREEN}+${RESET} passender Uploads-Tar: $(basename "$uploads") ($(du -sh "$uploads" | awk '{print $1}'))"
	else
		echo "  ${YELLOW}-${RESET} kein passender Uploads-Tar gefunden — nur DB wird restored."
		uploads=""
	fi

	echo
	warn "Folgende Schritte werden ausgeführt:"
	echo "  1) docker compose stop app-${app} migrate-${app}"
	echo "  2) restore.sh ${app} $(basename "$dump")"
	[[ -n "$uploads" ]] && echo "     + Uploads aus $(basename "$uploads")"
	echo "  3) docker compose up -d migrate-${app} app-${app}"
	echo
	confirm "Wirklich restoren?" || {
		info "Abgebrochen."
		return
	}
	docker compose stop "app-${app}" "migrate-${app}" || true
	"$SCRIPT_DIR/restore.sh" "$app" "$dump" ${uploads:+"$uploads"}
	docker compose up -d "migrate-${app}" "app-${app}"
}

# ---------- logs ----------
cmd_logs() {
	require_env
	local svc="${1:-}"
	if [[ -z "$svc" ]]; then
		exec docker compose logs -f --tail=100 app-ringwerk app-treffsicher caddy
	else
		exec docker compose logs -f --tail=200 "$svc"
	fi
}

# ---------- psql ----------
cmd_psql() {
	require_env
	require_docker
	local app="${1:-}"
	is_valid_app "$app" || {
		err "Aufruf: vereinsheim psql <ringwerk|treffsicher>"
		return 1
	}
	exec docker compose exec db psql -U postgres -d "$app"
}

# ---------- migrations ----------
cmd_migrations() {
	require_env
	require_docker
	local app="${1:-}"
	if ! is_valid_app "$app"; then
		echo "  Welche App?"
		echo "    1) ringwerk"
		echo "    2) treffsicher"
		read -r -p "  Wahl: " c
		case "$c" in 1) app=ringwerk ;; 2) app=treffsicher ;; *)
			err "Ungültig"
			return 1
			;;
		esac
	fi

	hr
	info "Migration-Status für $app"
	local out
	out="$(docker compose exec -T db psql -U postgres -d "$app" -At <<-SQL || true
		SELECT migration_name,
		       to_char(started_at, 'YYYY-MM-DD HH24:MI'),
		       CASE WHEN finished_at IS NOT NULL THEN 'applied'
		            WHEN rolled_back_at IS NOT NULL THEN 'rolled-back'
		            ELSE 'FAILED' END AS state
		FROM _prisma_migrations
		WHERE finished_at IS NULL AND rolled_back_at IS NULL
		ORDER BY started_at;
	SQL
	)"
	if [[ -z "$out" ]]; then
		ok "Keine fehlgeschlagenen Migrations für $app."
		echo
		echo "  Letzte 5 erfolgreiche Migrations:"
		docker compose exec -T db psql -U postgres -d "$app" -c \
			"SELECT migration_name, finished_at FROM _prisma_migrations WHERE finished_at IS NOT NULL ORDER BY finished_at DESC LIMIT 5;" 2>/dev/null || true
		return
	fi

	err "Fehlgeschlagene Migrations gefunden:"
	echo "$out" | while IFS='|' read -r name started state; do
		printf "    - %s  (started %s, %s)\n" "$name" "$started" "$state"
	done

	echo
	echo "${BOLD}Recovery-Optionen:${RESET}"
	echo "  1) Auto-Recovery erneut versuchen (= migrate-${app} neu starten)"
	echo "  2) Migration als ${GREEN}applied${RESET} markieren (DDL ist in DB schon vollzogen)"
	echo "  3) Migration als ${YELLOW}rolled-back${RESET} markieren (läuft beim nächsten Deploy neu)"
	echo "  4) Migrate-Container-Logs anzeigen"
	echo "  5) psql in $app öffnen (manuelles Aufräumen)"
	echo "  q) Zurück"
	read -r -p "  Wahl: " choice
	case "$choice" in
	1)
		info "Starte migrate-${app} neu …"
		docker compose up -d --force-recreate "migrate-${app}"
		docker compose logs -f --tail=50 "migrate-${app}" &
		local pid=$!
		sleep 5
		kill "$pid" 2>/dev/null || true
		;;
	2 | 3)
		local mode
		[[ "$choice" == 2 ]] && mode="--applied" || mode="--rolled-back"
		local mig
		read -r -p "  Migration-Name: " mig
		[[ -z "$mig" ]] && {
			err "Abgebrochen."
			return 1
		}
		warn "Setze ${mig} = ${mode}"
		confirm "Sicher?" || return
		docker compose run --rm "migrate-${app}" \
			node /app/node_modules/prisma/build/index.js migrate resolve "$mode" "$mig"
		;;
	4)
		exec docker compose logs --tail=200 "migrate-${app}"
		;;
	5)
		exec docker compose exec db psql -U postgres -d "$app"
		;;
	*) ;;
	esac
}

# ---------- shell ----------
cmd_shell() {
	require_env
	local svc="${1:-}"
	[[ -z "$svc" ]] && {
		err "Aufruf: vereinsheim shell <service>"
		return 1
	}
	exec docker compose exec "$svc" sh
}

# ---------- cron ----------
cmd_cron() {
	local backup_path="$REPO_DIR/scripts/backup.sh"
	local log_dir="$REPO_DIR/logs"
	local log_file="$log_dir/backup.log"
	local cron_line="0 3 * * * $backup_path >> $log_file 2>&1"
	if crontab -l 2>/dev/null | grep -qF "$backup_path"; then
		ok "Backup-Cron ist bereits eingetragen:"
		crontab -l 2>/dev/null | grep -F "$backup_path" | sed 's/^/    /'
		echo
		confirm "Eintrag entfernen?" && {
			(crontab -l 2>/dev/null | grep -vF "$backup_path") | crontab -
			ok "Entfernt."
		}
		return
	fi
	echo "  Eintrag der gesetzt wird:"
	echo "    $cron_line"
	confirm "Eintragen?" Y || {
		info "Abgebrochen."
		return
	}
	mkdir -p "$log_dir"
	(
		crontab -l 2>/dev/null
		echo "$cron_line"
	) | crontab -
	ok "Cron eingetragen. Nächster Lauf: 03:00 lokale Zeit."
	if [[ ! -d /var/backups/vereinsheim ]]; then
		warn "/var/backups/vereinsheim fehlt — wird beim ersten Lauf angelegt (sofern Schreibrechte)."
		warn "Bei Permission-Problemen: sudo mkdir -p /var/backups/vereinsheim && sudo chown \$USER /var/backups/vereinsheim"
	fi
}

# ---------- service controls ----------
cmd_up() {
	require_env
	require_docker
	exec docker compose up -d
}
cmd_down() {
	require_env
	require_docker
	confirm "Alle Services stoppen?" || return
	exec docker compose down
}
cmd_restart() {
	require_env
	require_docker
	local svc="${1:-}"
	[[ -z "$svc" ]] && {
		err "Aufruf: vereinsheim restart <service>"
		return 1
	}
	exec docker compose restart "$svc"
}

# ============================================================
# Interactive menu
# ============================================================
interactive_menu() {
	if is_local_mode; then
		interactive_menu_local
	else
		# Frische Workstation (weder Lokal-Config noch VPS-.env)? → auf dev-setup hinweisen,
		# bevor das VPS-Menü erscheint. Auf einem echten VPS existiert .env → kein Hinweis.
		if [[ ! -f "$ENV_FILE" ]]; then
			echo
			echo "  ${YELLOW}Frische Workstation?${RESET} Richte alles ein mit:  ${BOLD}./scripts/vereinsheim dev-setup${RESET}"
		fi
		interactive_menu_vps
	fi
}

interactive_menu_local() {
	load_local_config
	while :; do
		echo
		echo "${BOLD}vereinsheim${RESET}  ${DIM}VPS: ${VPS_HOST:-?}${RESET}"
		echo
		echo "  ${BOLD}Entwicklungsumgebung${RESET}"
		echo "  d) dev-setup  Workstation arbeitsfähig machen  ${DIM}(idempotent)${RESET}"
		echo
		echo "  ${BOLD}Release-Workflow${RESET}"
		echo "  1) build      Beide Apps bauen + pushen"
		echo "  2) release    build + ssh-Deploy  ${DIM}(Standard-Release)${RESET}"
		echo "  3) ssh        Shell auf dem VPS"
		echo "  4) remote …   Befehl auf dem VPS"
		echo "  5) upload     Datei(en) → VPS ~/migration/"
		echo "  6) download   Backup ← VPS"
		echo
		echo "  ${BOLD}Lokale Testumgebung${RESET}"
		echo "  7) local-build         Alle 4 Images lokal bauen  ${DIM}(kein Push)${RESET}"
		echo "  8) local-pull          Backups + Image-Tags vom VPS holen"
		echo "  9) local-up            Stack starten  ${DIM}(vorhandene Volumes)${RESET}"
		echo " 10) local-up --restore  Stack neu aufsetzen  ${DIM}(clean + Produktionsdaten)${RESET}"
		echo " 11) local-down          Stack stoppen"
		echo
		echo "  ${BOLD}Host-Dev-Datenbank${RESET}  ${DIM}(docker-compose.dev.yml)${RESET}"
		echo " 12) dev-restore         Prod-Dump aus ./backups/ → Dev-DB  ${DIM}(beide Apps)${RESET}"
		echo
		echo "  q) Beenden  ${DIM}· local-setup: VPS-Verbindung ändern${RESET}"
		read -r -p "  » " c
		case "$c" in
		d | D) cmd_dev_setup ;;
		1) cmd_build ;;
		2) cmd_release ;;
		3) cmd_ssh ;;
		4) interactive_remote_pick ;;
		5)
			read -r -p "  Datei(en) zum Hochladen (Space-getrennt): " -a files
			[[ ${#files[@]} -gt 0 ]] && cmd_upload "${files[@]}"
			;;
		6)
			read -r -p "  Dateiname (Enter = Liste anzeigen): " fname
			if [[ -z "$fname" ]]; then
				cmd_download
			else
				read -r -p "  Zielverzeichnis [.]: " tdir
				cmd_download "$fname" "${tdir:-.}"
			fi
			;;
		7) cmd_local_build ;;
		8) cmd_local_pull ;;
		9) cmd_local_up ;;
		10) cmd_local_up --restore ;;
		11) cmd_local_down ;;
		12) cmd_dev_restore ;;
		q | Q | "") break ;;
		*) warn "Ungültige Auswahl" ;;
		esac
	done
}

interactive_menu_vps() {
	while :; do
		echo
		echo "${BOLD}vereinsheim${RESET}  ${DIM}VPS-Mode${RESET}"
		echo
		echo "  ${BOLD}Übersicht & Diagnose${RESET}"
		echo "  1) status     Services, Volumes, Backups, .env, Cron"
		echo "  2) logs       Logs folgen"
		echo "  3) env-check  .env auf Vollständigkeit prüfen"
		echo
		echo "  ${BOLD}Deploy & Backup${RESET}"
		echo "  4) deploy     Pre-Backup + Pull + Up"
		echo "  5) rollback   Auf vorherigen Deploy zurück"
		echo "  6) backup     Backup jetzt manuell erstellen"
		echo "  7) restore    Interaktiver Restore aus Backup"
		echo
		echo "  ${BOLD}Datenbank${RESET}"
		echo "  8) psql        DB-Shell"
		echo "  9) migrations  Migration-Status + Recovery"
		echo
		echo "  ${BOLD}Infrastruktur${RESET}"
		echo " 10) setup       .env-Wizard"
		echo " 11) cron        Backup-Cron installieren/prüfen"
		echo " 12) shell       Bash-Shell im Container"
		echo " 13) up/down/restart"
		echo
		echo "  q) Beenden  ${DIM}· Lokal-Modus: ./scripts/vereinsheim local-setup${RESET}"
		read -r -p "  » " c
		case "$c" in
		1) cmd_status ;;
		2)
			read -r -p "  Service (Enter = Apps + caddy): " svc
			cmd_logs "$svc"
			;;
		3) cmd_env_check ;;
		4) cmd_deploy ;;
		5) cmd_rollback ;;
		6) cmd_backup ;;
		7) cmd_restore ;;
		8) cmd_psql_interactive ;;
		9) cmd_migrations ;;
		10) cmd_setup ;;
		11) cmd_cron ;;
		12)
			read -r -p "  Service: " svc
			[[ -n "$svc" ]] && cmd_shell "$svc"
			;;
		13) interactive_service_control ;;
		q | Q | "") break ;;
		*) warn "Ungültige Auswahl" ;;
		esac
	done
}

interactive_remote_pick() {
	echo "  Welcher Remote-Befehl?"
	echo "    1) status"
	echo "    2) deploy   ${DIM}(ohne lokales build, nur pull+up am VPS)${RESET}"
	echo "    3) backup"
	echo "    4) logs"
	echo "    5) eigener Befehl"
	read -r -p "  Wahl: " c
	case "$c" in
	1) cmd_remote status ;;
	2) cmd_remote deploy ;;
	3) cmd_remote backup ;;
	4) cmd_remote logs ;;
	5)
		read -r -p "  Subcommand mit Args: " sub
		[[ -n "$sub" ]] && eval cmd_remote "$sub"
		;;
	*) warn "Ungültig" ;;
	esac
}

cmd_psql_interactive() {
	echo "  1) ringwerk"
	echo "  2) treffsicher"
	read -r -p "  Wahl: " c
	case "$c" in
	1) cmd_psql ringwerk ;;
	2) cmd_psql treffsicher ;;
	*) warn "Ungültig" ;;
	esac
}

interactive_service_control() {
	echo "  1) up (alle starten)"
	echo "  2) down (alle stoppen)"
	echo "  3) restart <service>"
	read -r -p "  Wahl: " c
	case "$c" in
	1) cmd_up ;;
	2) cmd_down ;;
	3)
		read -r -p "  Service: " svc
		cmd_restart "$svc"
		;;
	*) warn "Ungültig" ;;
	esac
}

# ============================================================
# Main dispatch
# ============================================================
main() {
	if [[ $# -eq 0 ]]; then
		if [[ ! -t 0 ]]; then
			err "Interaktives Menü braucht ein TTY. Verwende einen Subcommand:"
			cmd_help
			exit 1
		fi
		interactive_menu
		return
	fi
	local cmd="$1"
	shift || true
	case "$cmd" in
	help | -h | --help) cmd_help ;;
	# Local side
	dev-setup) cmd_dev_setup "$@" ;;
	local-setup) cmd_local_setup "$@" ;;
	build) cmd_build "$@" ;;
	release) cmd_release "$@" ;;
	ssh) cmd_ssh "$@" ;;
	remote) cmd_remote "$@" ;;
	upload) cmd_upload "$@" ;;
	download) cmd_download "$@" ;;
	local-build) cmd_local_build "$@" ;;
	local-pull) cmd_local_pull "$@" ;;
	local-up) cmd_local_up "$@" ;;
	local-down) cmd_local_down "$@" ;;
	dev-restore) cmd_dev_restore "$@" ;;
	# VPS side
	setup) cmd_setup "$@" ;;
	env-check) cmd_env_check "$@" ;;
	status) cmd_status "$@" ;;
	deploy) cmd_deploy "$@" ;;
	rollback) cmd_rollback "$@" ;;
	backup) cmd_backup "$@" ;;
	restore) cmd_restore "$@" ;;
	logs) cmd_logs "$@" ;;
	psql) cmd_psql "$@" ;;
	migrations) cmd_migrations "$@" ;;
	shell) cmd_shell "$@" ;;
	cron) cmd_cron "$@" ;;
	up) cmd_up "$@" ;;
	down) cmd_down "$@" ;;
	restart) cmd_restart "$@" ;;
	*)
		err "Unbekanntes Kommando: $cmd"
		cmd_help
		exit 1
		;;
	esac
}

main "$@"
