# Datenbankverbindung
DATABASE_URL=postgresql://liga:liga@db:5432/liga

# NextAuth
NEXTAUTH_SECRET=dev-secret-fuer-lokale-entwicklung-min32z
NEXTAUTH_URL=http://localhost:3000

# Erster Admin-Account (wird beim ersten Start angelegt, nur wenn noch kein Admin existiert)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-passwort-12

# Uploads (Meyton PDF)
UPLOAD_DIR=/app/uploads

# Anzeigetimezone (IANA, z.B. Europe/Berlin). DB speichert immer UTC.
DISPLAY_TIME_ZONE=Europe/Berlin

# Rate Limiting
# Bei Reverse-Proxy-Deployment (z.B. vereinsheim-Repo): auf true setzen,
# damit echte Client-IPs aus X-Forwarded-For für Rate-Limiting verwendet werden.
AUTH_TRUST_PROXY_HEADERS=false
AUTH_RATE_LIMIT_MAX_BUCKETS=10000

# Prisma Migration Recovery
PRISMA_AUTO_RESOLVE_FAILED_MIGRATIONS=true
PRISMA_AUTO_RESOLVE_UNKNOWN_FAILED_MIGRATIONS=false

# PostgreSQL (für docker-compose.prod.yml)
POSTGRES_USER=liga
POSTGRES_PASSWORD=liga
POSTGRES_DB=liga
