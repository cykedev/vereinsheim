# ── Host-Dev im Monorepo ─────────────────────────────────────────────────────
# Postgres kommt aus der Root-`docker-compose.dev.yml` (geteilter Container,
# zwei DBs). Die App läuft auf dem Host via `pnpm dev` → Verbindung via
# localhost:5432 auf die Dev-DB "ringwerk" (gleicher Name wie in Prod).
# Kopiere diese Datei nach `.env` (gitignored) für lokale Entwicklung.

# Datenbankverbindung
DATABASE_URL=postgresql://ringwerk:ringwerk@localhost:5432/ringwerk

# NextAuth
NEXTAUTH_SECRET=dev-secret-fuer-lokale-entwicklung-min32z
NEXTAUTH_URL=http://localhost:3000

# Erster Admin-Account (wird beim ersten Start angelegt, nur wenn noch kein Admin existiert)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-passwort-12

# Uploads
UPLOAD_DIR=./uploads

# Anzeigetimezone (IANA, z.B. Europe/Berlin). DB speichert immer UTC.
DISPLAY_TIME_ZONE=Europe/Berlin

# Rate Limiting (Host-Dev ohne Reverse-Proxy → false)
AUTH_TRUST_PROXY_HEADERS=false
AUTH_RATE_LIMIT_MAX_BUCKETS=10000

# Prisma Migration Recovery
PRISMA_AUTO_RESOLVE_FAILED_MIGRATIONS=true
PRISMA_AUTO_RESOLVE_UNKNOWN_FAILED_MIGRATIONS=false
