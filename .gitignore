# Secrets / lokale Konfiguration
.env*
!.env.example
.vereinsheim.local

# DB-Dumps und Backups
*.dump
*.dump.gz
*.sql.gz
backups/
migration/

# Caddy / Docker artefacts (sollten als Volumes leben, nicht im Repo)
caddy_data/
caddy_config/

# Monorepo: Node / pnpm / Turborepo (per-App-Artefakte deckt apps/*/.gitignore ab)
node_modules/
.turbo/
*.tsbuildinfo
.pnpm-store/
pnpm-debug.log*
# turbo prune Docker-Build-Kontext (transient, von build-and-push.sh erzeugt)
out/
# Agent-Harness (ADR-016/018): lokaler CodeGraph-Index (re-buildbar) + Superpowers-Artefakte
.codegraph/
.superpowers/
# Autopilot-Marker (ADR-023): transient, maschinen-lokal — aktiviert den autopilot-guard-Hook
.claude/.autopilot-active
# Knowledge-Capture-Marker (ADR-025): transient, maschinen-lokal, per-HEAD
.claude/.knowledge-nudge
# Validate-/Review-Berichte (ADR-018-Nachtrag): lokal-only, nie team-geteilt — siehe decisions.md
reports/*
!reports/README.md

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Obsidian-Vault: GUI-/Workspace-State ist maschinen-lokal (der Vault selbst ist versioniert; ADR-025)
vault/.obsidian/
